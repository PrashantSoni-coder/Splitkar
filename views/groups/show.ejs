<div class="page-container">
  <div class="group-show-header">
    <div>
      <h1><%= group.name %></h1>
      <% if (group.description) { %><p class="group-desc"><%= group.description %></p><% } %>
      <p class="group-meta"><%= group.members.length %> member<%= group.members.length !== 1 ? "s" : "" %></p>
    </div>
    <div class="header-actions">
      <a href="/activity?group=<%= group._id %>" class="btn btn-secondary">Activity</a>
      <% if (group.createdBy._id.toString() === user._id.toString()) { %>
        <form action="/groups/<%= group._id %>?_method=DELETE" method="POST" onsubmit="return confirm('Delete this group and all its expenses?')">
          <button type="submit" class="btn btn-danger">Delete Group</button>
        </form>
      <% } %>
    </div>
  </div>

  <div class="balance-cards">
    <div class="balance-card balance-owed">
      <span class="balance-label">You are owed</span>
      <span class="balance-amount">₹<%= totalOwed.toFixed(2) %></span>
    </div>
    <div class="balance-card balance-owing">
      <span class="balance-label">You owe</span>
      <span class="balance-amount">₹<%= totalOwing.toFixed(2) %></span>
    </div>
  </div>

  <!-- Add Expense Form -->
  <div class="card add-expense-card">
    <h2>Add Expense</h2>
    <form action="/expenses" method="POST" class="inline-form">
      <input type="hidden" name="groupId" value="<%= group._id %>"/>
      <div class="form-row">
        <div class="form-group">
          <input type="text" name="title" placeholder="Expense title" required maxlength="100"/>
        </div>
        <div class="form-group">
          <input type="number" name="amount" placeholder="Amount (₹)" min="0.01" step="0.01" required/>
        </div>
        <div class="form-group">
          <input type="text" name="notes" placeholder="Notes (optional)" maxlength="300"/>
        </div>
        <button type="submit" class="btn btn-primary">Add</button>
      </div>
    </form>
  </div>

  <!-- Members -->
  <div class="card members-card">
    <div class="card-header">
      <h2>Members</h2>
    </div>
    <ul class="members-list">
      <% group.members.forEach(member => { %>
        <li class="member-item">
          <div class="member-avatar"><%= member.name.charAt(0).toUpperCase() %></div>
          <span><%= member.name %> <% if (member._id.toString() === user._id.toString()) { %><span class="badge">You</span><% } %></span>
        </li>
      <% }) %>
    </ul>
    <% if (group.createdBy._id.toString() === user._id.toString()) { %>
      <form action="/groups/<%= group._id %>/invite" method="POST" class="invite-form">
        <input type="email" name="email" placeholder="Invite by email" required/>
        <button type="submit" class="btn btn-secondary">Invite</button>
      </form>
    <% } %>
  </div>

  <!-- Expenses List -->
  <div class="section-header"><h2>Expenses</h2></div>
  <% if (expenses.length === 0) { %>
    <div class="empty-state"><p>No expenses yet. Add one above!</p></div>
  <% } else { %>
    <div class="expense-list">
      <% expenses.forEach(expense => { %>
        <%- include('../partials/expenseCard', { expense, user }) %>
      <% }) %>
    </div>
  <% } %>
</div>
