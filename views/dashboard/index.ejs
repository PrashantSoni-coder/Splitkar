<div class="dashboard-container">
  <div class="dashboard-header">
    <h1>Welcome, <%= user.name %> 👋</h1>
    <p class="subtitle">Here's your expense overview</p>
  </div>

  <div class="balance-cards">
    <div class="balance-card balance-owed">
      <span class="balance-label">You are owed</span>
      <span class="balance-amount">₹<%= totalOwed %></span>
    </div>
    <div class="balance-card balance-owing">
      <span class="balance-label">You owe</span>
      <span class="balance-amount">₹<%= totalOwing %></span>
    </div>
  </div>

  <div class="section-header">
    <h2>Recent Groups</h2>
    <a href="/groups/new" class="btn btn-primary">+ New Group</a>
  </div>

  <% if (groups.length === 0) { %>
    <div class="empty-state">
      <p>No groups yet. Create one to get started!</p>
      <a href="/groups/new" class="btn btn-primary">Create Group</a>
    </div>
  <% } else { %>
    <div class="group-list">
      <% groups.forEach(group => { %>
        <a href="/groups/<%= group._id %>" class="group-card">
          <div class="group-card-info">
            <h3><%= group.name %></h3>
            <p><%= group.members.length %> member<%= group.members.length !== 1 ? "s" : "" %></p>
          </div>
          <span class="arrow">&rsaquo;</span>
        </a>
      <% }) %>
    </div>
    <div class="view-all">
      <a href="/groups">View all groups &rarr;</a>
    </div>
  <% } %>
</div>
