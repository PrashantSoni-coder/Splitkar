<section class="hero">
  <div class="hero-badge">
    <span class="hero-badge-dot"></span>
    Built for India &nbsp;·&nbsp; INR &nbsp;·&nbsp; UPI
  </div>

  <h1 class="hero-title">
    <span class="line1">Split expenses.</span>
